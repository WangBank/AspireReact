APP_PORT=5516
ASPIRE_DASHBOARD_IMAGE=mcr.microsoft.com/dotnet/aspire-dashboard:latest
ASPIRE_DASHBOARD_BIND_HOST=127.0.0.1
ASPIRE_DASHBOARD_PORT=18888
# If an existing data volume was created by another postgres major version,
# pin the old major here first, for example: postgres:17-alpine
POSTGRES_IMAGE=postgres:latest
POSTGRES_PORT=5432
POSTGRES_DB=lies
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

REDIS_PORT=6379

# HS256 requires at least 32 bytes for the signing key.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ISSUER=Lies.Server
JWT_AUDIENCE=Lies.Client

RAPIDOCR_AUTO_DOWNLOAD_MODELS=true
